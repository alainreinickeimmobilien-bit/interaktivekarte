# Kopieren nach .env und Werte anpassen. NICHT ins Repo/Image einchecken.

# Passwort für den Login der Webapp
APP_PASSWORD=hier-ein-sicheres-passwort-eintragen

# Zufälliger String zum Signieren der Session-Cookies (z.B. mit: openssl rand -hex 32)
SECRET_KEY=hier-einen-zufaelligen-string-eintragen
